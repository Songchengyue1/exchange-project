DEBUG=true
JWT_SECRET=please-use-a-long-random-secret
CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
SEED_ON_STARTUP=true

# PostgreSQL（推荐：与 docker-compose.yml 中 postgres 服务一致）
# 方式一：完整连接串（优先级最高）
DATABASE_URL=postgresql+psycopg://secondhand:secondhand@127.0.0.1:5432/secondhand

# 方式二：分项配置（未设置 DATABASE_URL 时自动拼装）
# POSTGRES_HOST=127.0.0.1
# POSTGRES_PORT=5432
# POSTGRES_USER=secondhand
# POSTGRES_PASSWORD=secondhand
# POSTGRES_DB=secondhand

# 本地仅快速演示可临时改回 SQLite（不支持 pgvector / 全文 RAG）
# DATABASE_URL=sqlite:///./data/app.db

# M5 AI — 本地 Ollama（需先 ollama pull mxbai-embed-large / qwen3.5:0.8b）
AI_ENABLED=true
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_CHAT_MODEL=qwen3.5:0.8b
OLLAMA_EMBED_MODEL=mxbai-embed-large
AI_SEARCH_USE_LLM=false
AI_EMBED_BATCH_ON_STARTUP=false
AI_CHAT_KEYWORD_FIRST=true
AI_CHAT_USE_VECTOR=false
AI_CHAT_MAX_HISTORY=4
AI_CHAT_NUM_PREDICT=320
OLLAMA_KEEP_ALIVE=15m
